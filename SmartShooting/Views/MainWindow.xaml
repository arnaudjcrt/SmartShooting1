<Window x:Class="SmartShooting.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Shooting"
        Height="720"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#0B1020">

    <Window.Resources>

        <Style TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

    </Window.Resources>

    <Grid Margin="28">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <Border Grid.Row="0"
                Background="#111827"
                CornerRadius="22"
                Padding="20"
                Margin="0,0,0,20">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- TITRE -->

                <StackPanel Grid.Column="0">

                    <TextBlock Text="SMART SHOOTING"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="Jeu interactif Arduino • Distance temps réel"
                               FontSize="15"
                               Foreground="#94A3B8"/>

                </StackPanel>

                <!-- BOUTONS -->

                <WrapPanel Grid.Column="1"
                           VerticalAlignment="Center">

                    <ComboBox x:Name="PortComboBox"/>

                    <Button x:Name="BoutonConnexion"
                            Content="Connecter"
                            Width="120"
                            Background="#16A34A"
                            Click="Connexion_Click"/>

                    <Button Content="Actualiser"
                            Width="120"
                            Background="#334155"
                            Click="ActualiserPorts_Click"/>

                    <Button Content="Mode test"
                            Width="120"
                            Background="#0EA5E9"
                            Click="ModeTest_Click"/>

                </WrapPanel>

            </Grid>

        </Border>

        <!-- CONTENU -->

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>


            <!-- PARTIE GAUCHE -->

            <Border Grid.Column="0"
                    Background="#151B2E"
                    CornerRadius="25"
                    Padding="30"
                    Margin="0,0,10,0">

                <StackPanel>

                    <TextBlock Text="Distance demandée"
                               FontSize="20"
                               Foreground="#94A3B8"/>

                    <TextBlock x:Name="TexteDistanceDemandee"
                               Text="0 cm"
                               FontSize="90"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,20"/>


                    <Border Background="#0F172A"
                            CornerRadius="20"
                            Padding="20"
                            Margin="0,0,0,25">

                        <StackPanel>

                            <TextBlock Text="Distance actuelle"
                                       FontSize="18"
                                       Foreground="#94A3B8"/>

                            <TextBlock x:Name="TexteDistanceActuelle"
                                       Text="0 cm"
                                       FontSize="44"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock x:Name="TexteDistanceArrondie"
                                       Text="Arrondi : 0 cm"
                                       FontSize="18"
                                       Foreground="#CBD5E1"/>

                        </StackPanel>

                    </Border>

                    <ProgressBar x:Name="BarreDistance"
                                 Height="20"
                                 Minimum="0"
                                 Maximum="300"
                                 Margin="0,0,0,25"/>


                    <Button Content="🎯 Nouvelle distance"
                            Height="50"
                            FontSize="15"
                            Background="#7C3AED"
                            Click="NouvelleDistance_Click"/>

                    <Button Content="↻ Réinitialiser score"
                            Height="50"
                            FontSize="15"
                            Background="#475569"
                            Click="ResetScore_Click"/>

                </StackPanel>

            </Border>


            <!-- PARTIE DROITE -->

            <Border Grid.Column="1"
                    Background="#151B2E"
                    CornerRadius="25"
                    Padding="30"
                    Margin="10,0,0,0">

                <StackPanel>

                    <TextBlock Text="Indication"
                               FontSize="20"
                               Foreground="#94A3B8"/>

                    <Border x:Name="BlocMessage"
                            Background="#334155"
                            CornerRadius="20"
                            Padding="20"
                            Margin="0,10,0,20">

                        <TextBlock x:Name="TexteMessage"
                                   Text="En attente..."
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextAlignment="Center"/>

                    </Border>


                    <TextBlock Text="Résultat du tir"
                               FontSize="20"
                               Foreground="#94A3B8"/>

                    <Border x:Name="BlocResultat"
                            Background="#0F172A"
                            CornerRadius="20"
                            Padding="20"
                            Margin="0,10,0,20">

                        <TextBlock x:Name="TexteResultat"
                                   Text="--"
                                   FontSize="35"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextAlignment="Center"/>

                    </Border>


                    <Grid Margin="0,0,0,20">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#0F172A"
                                CornerRadius="15"
                                Padding="15"
                                Margin="0,0,5,0">

                            <TextBlock x:Name="TexteScore"
                                       Text="Score : 0"
                                       FontSize="25"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                        </Border>


                        <Border Grid.Column="1"
                                Background="#0F172A"
                                CornerRadius="15"
                                Padding="15"
                                Margin="5,0,0,0">

                            <TextBlock x:Name="TexteTirs"
                                       Text="Tirs : 0"
                                       FontSize="25"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                        </Border>

                    </Grid>


                    <TextBox x:Name="ZoneLogs"
                             Height="160"
                             Background="#020617"
                             Foreground="#CBD5E1"
                             BorderThickness="0"
                             Padding="10"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"/>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</Window>